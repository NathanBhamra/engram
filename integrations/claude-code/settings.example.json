{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python ~/engram/integrations/claude-code/engram_recall_hook.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python ~/engram/integrations/claude-code/engram_store_hook.py"
          }
        ]
      }
    ]
  }
}
